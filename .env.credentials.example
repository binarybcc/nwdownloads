# NWDownloads Production Credentials Template
# Copy this file to .env.credentials and fill in your actual credentials
# SECURITY: .env.credentials is gitignored - never commit actual credentials!

## SSH Access (Synology NAS)
SSH_HOST=192.168.1.254
SSH_USER=it
SSH_PASSWORD=your_ssh_password_here
SSH_PORT=22

## Database (Production - Native MariaDB via Unix Socket)
PROD_DB_CONNECTION=mysql
PROD_DB_SOCKET=/run/mysqld/mysqld10.sock
PROD_DB_DATABASE=circulation_dashboard
PROD_DB_USERNAME=root
PROD_DB_PASSWORD=your_production_db_password_here

## Application URLs
PROD_URL=https://cdash.upstatetoday.com
PROD_INTERNAL_URL=http://192.168.1.254:8081

## SFTP Access (Newzware - Publication Data Downloads)
SFTP_TJ_HOST=tj.upstatetoday.com
SFTP_TJ_PORT=22
SFTP_TJ_USER=newzwaresftp
SFTP_TJ_PASSWORD=your_sftp_password_here

## Setup Instructions
# 1. Copy this file: cp .env.credentials.example .env.credentials
# 2. Edit .env.credentials and replace all "your_*_here" values
# 3. Test: source .env.credentials && echo "SSH_HOST=$SSH_HOST"
# 4. Use in scripts: source .env.credentials before running commands

## Error Handling
# If you get "command not found" errors, ensure you've sourced the file:
#   source .env.credentials
#
# If variables are empty, check for syntax errors in .env.credentials
